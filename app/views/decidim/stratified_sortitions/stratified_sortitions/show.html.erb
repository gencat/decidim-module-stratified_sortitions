<% add_decidim_meta_tags({
                           description: decidim_sanitize_editor(translated_attribute(stratified_sortition.description)),
                           title: decidim_escape_translated(stratified_sortition.title),
                           url: stratified_sortition_url(stratified_sortition.to_param)
                         }) %>

<%
edit_link(
  resource_locator(stratified_sortition).edit,
  :update,
  :stratified_sortition,
  stratified_sortition:
)
%>

<%= append_javascript_pack_tag "decidim_stratified_sortitions" %>
<%= append_stylesheet_pack_tag "decidim_stratified_sortitions" %>

<%= render layout: "layouts/decidim/shared/layout_item", locals: { back_path: :stratified_sortitions, commentable: nil } do %>
  <section class="layout-main__section layout-main__heading">
    <h1 class="h1 decorator mb-4">
      <%= decidim_escape_translated(stratified_sortition.title) %>
    </h1>
  </section>

  <% if translated_attribute(stratified_sortition.description).present? %>
    <section class="layout-main__section">
      <h2 class="h3">
        <%= t("description", scope: "decidim.stratified_sortitions.stratified_sortitions.show") %>
      </h2>
      <div class="editor-content">
        <%= decidim_sanitize_editor_admin translated_attribute stratified_sortition.description %>
      </div>
    </section>
  <% end %>

  <% if translated_attribute(stratified_sortition.selection_criteria).present? %>
    <section class="layout-main__section">
      <h2 class="h3">
        <%= t("selection_criteria", scope: "decidim.stratified_sortitions.stratified_sortitions.show") %>
      </h2>
      <div class="editor-content">
        <%= decidim_sanitize_editor_admin translated_attribute stratified_sortition.selection_criteria %>
      </div>
    </section>
  <% end %>

  <% if translated_attribute(stratified_sortition.selected_profiles_description).present? %>
    <section class="layout-main__section">
      <h2 class="h3">
        <%= t("selected_profiles_description", scope: "decidim.stratified_sortitions.stratified_sortitions.show") %>
      </h2>
      <div class="editor-content">
        <%= decidim_sanitize_editor_admin translated_attribute stratified_sortition.selected_profiles_description %>
      </div>
    </section>
  <% end %>

  <% content_for :aside do %>
    <section class="layout-aside__section">
      <%= render partial: "results_count", locals: { stratified_sortition: } %>
    </section>
    <section class="layout-aside__section">
      <div class="text-sm text-gray-2 uppercase font-semibold mb-4">
        <%= t("sortition_details", scope: "decidim.stratified_sortitions.stratified_sortitions.show") %>
      </div>
      <div class="stratified-sortition__aside-element bg-background p-4 rounded">
        <div class="stratified-sortition__aside-element-item">
          <span class="stratified-sortition__aside-element-item__title">
            <%= t("status", scope: "decidim.stratified_sortitions.stratified_sortitions.show") %>
          </span>
          <span class="stratified-sortition__aside-element-item__text">
            <%= t(stratified_sortition.status, scope: "decidim.stratified_sortitions.stratified_sortitions.show.statuses") %>
          </span>
        </div>
        <div class="stratified-sortition__aside-element-item">
          <span class="stratified-sortition__aside-element-item__title">
            <%= t("algorithm_description", scope: "decidim.stratified_sortitions.stratified_sortitions.show") %>
          </span>
          <div class="stratified-sortition__aside-element-item">
            <%= link_to t("algorithm_name", scope: "decidim.stratified_sortitions.stratified_sortitions.show"), Decidim::StratifiedSortitions.leximin_algorithm, class: "stratified-sortition__aside-element-item__title" %>
          </div>
        </div>
        <% if stratified_sortition.panel_portfolio&.sampled? %>
          <div class="stratified-sortition__aside-element-item">
            <span class="stratified-sortition__aside-element-item__title">
              <%= t("random_value_used", scope: "decidim.stratified_sortitions.stratified_sortitions.show") %>
            </span>
            <span class="stratified-sortition__aside-element-item__text">
              <%= stratified_sortition.panel_portfolio.random_value_used %>
            </span>
          </div>
          <div class="stratified-sortition__aside-element-item">
            <span class="stratified-sortition__aside-element-item__title">
              <%= t("selected_at", scope: "decidim.stratified_sortitions.stratified_sortitions.show") %>
            </span>
            <span class="stratified-sortition__aside-element-item__text">
              <%= l stratified_sortition.panel_portfolio.selected_at, format: :decidim_short %>
            </span>
          </div>
        <% end %>
      </div>
    </section>
    <section class="layout-aside__section actions__secondary">
      <%= cell "decidim/share_button", nil %>
    </section>
  <% end %>
  <% content_for :item_footer do %>
    <ul class="metadata__container layout-main__section" data-metadata-footer>
      <%= content_tag :li, resource_reference(stratified_sortition), class: "metadata__item" %>
    </ul>
  <% end %>
<% end %>
